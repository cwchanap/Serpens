{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Serpens",
	"version": "0.0.1",
	"identifier": "com.serpens.game",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Serpens",
				"width": 1280,
				"height": 820,
				"minWidth": 960,
				"minHeight": 640
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"icon": ["icons/icon.png"],
		"targets": "all"
	}
}
